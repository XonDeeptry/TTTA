# DOMAIN lấy từ biến môi trường (docker-compose). Dùng "localhost" khi dev local.
{$DOMAIN:localhost} {
	handle /webhook* {
		reverse_proxy zalo-gateway:3000
	}

	handle /healthz {
		reverse_proxy zalo-gateway:3000
	}

	handle /api* {
		uri strip_prefix /api
		reverse_proxy core-api:3001
	}

	# Dashboard SPA (M4) — build container sao chép dist/ vào volume dashboarddist,
	# Caddy chỉ serve tĩnh, không cần Node/nginx chạy runtime.
	handle {
		root * /srv/dashboard
		file_server
		try_files {path} /index.html
	}
}
