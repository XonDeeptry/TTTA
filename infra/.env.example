# ============================================================
# .env CHỈ chứa secrets HẠ TẦNG (v1.2).
# Mọi cấu hình ỨNG DỤNG (Zalo app/OA, token, khóa LLM, ngưỡng clip,
# guard 48h…) được nhập qua UI dashboard (màn Cấu hình hệ thống),
# lưu ở bảng `settings` và mirror sang Redis — KHÔNG cấu hình ở đây.
# Các biến ZALO_*/GEMINI_*/OPENAI_* dưới cùng chỉ là fallback cho DEV
# khi chưa có dashboard; production để trống.
# ============================================================

# ==== Domain (Caddy tự xin HTTPS) ====
DOMAIN=bot.example.com

# ==== PostgreSQL ====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ilm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ilm

# ==== Redis ====
REDIS_URL=redis://redis:6379

# ==== RabbitMQ ====
RABBITMQ_DEFAULT_USER=ilm
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_URL=amqp://ilm:change-me@rabbitmq:5672

# ==== Ports nội bộ ====
GATEWAY_PORT=3000
CORE_API_PORT=3001

# ==== core-api (M2) ====
# DATABASE_URL thật (dùng bởi container) được ghép trong docker-compose.yml từ POSTGRES_*
# ở trên — .env KHÔNG nội suy biến, nên dòng dưới chỉ để chạy `prisma migrate dev` từ máy dev
# (Postgres bind loopback :5432, xem docker-compose.yml).
DATABASE_URL=postgresql://ilm:change-me@localhost:5432/ilm
# Bí mật ký session cookie (dashboard admin/staff) — bắt buộc đổi ở production.
SESSION_SECRET=change-me-session-secret
# Token dùng chung giữa core-api và grading-worker (M3) cho các endpoint /internal/*.
INTERNAL_API_TOKEN=change-me-internal-token
# Tài khoản admin đầu tiên, tự tạo khi khởi động nếu bảng dashboard_users còn trống.
CORE_API_BOOTSTRAP_ADMIN_EMAIL=
CORE_API_BOOTSTRAP_ADMIN_PASSWORD=

# ==== DEV-ONLY fallback (production: cấu hình qua dashboard UI) ====
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ID=
ZALO_INITIAL_ACCESS_TOKEN=
ZALO_INITIAL_REFRESH_TOKEN=
ZALO_WEBHOOK_SECRET=
GEMINI_API_KEY=
OPENAI_API_KEY=
# Van chi phí (mục 3.5) — giây; mặc định 420 (7 phút) nếu để trống, xem grading-worker/src/grading_worker/pipeline.py
MAX_CLIP_DURATION_SEC=
